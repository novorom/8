{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/brands/layout,_N_T_/brands/[brand]/layout,_N_T_/brands/[brand]/page,_N_T_/brands/kerama-marazzi"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/brands/$d$brand/__PAGE__",
    "/brands/$d$brand",
    "/brands",
    "/_index",
    "/_head"
  ]
}