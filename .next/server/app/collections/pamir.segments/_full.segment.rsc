1f:Ta88,{"@context":"https://schema.org","@type":"ItemList","name":"Коллекция Pamir Cersanit","description":"Pamir — изысканная коллекция в формате 45×90 см, имитирующая горный природный камень. Три цветовых варианта — светло-бежевый, светло-серый и тёмно-серый — воспроизводят характерные вариации натурального камня с прожилками.","url":"https://plitki-spb.ru/collections/pamir","numberOfItems":6,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"Керамогранит Cersanit Pamir  светло-бежевый ректификат  44,8x89,8 A17697","url":"https://plitki-spb.ru/catalog/keramogranit-pamir-svetlo-bezhevyy-45x90","offers":{"@type":"Offer","price":1386,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"Керамогранит Cersanit Pamir  темно-серый ректификат  рельеф  44,8x89,8 A17781","url":"https://plitki-spb.ru/catalog/keramogranit-pamir-temno-seryy-45x90","offers":{"@type":"Offer","price":1386,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":3,"item":{"@type":"Product","name":"Керамогранит Cersanit Pamir  светло-серый ректификат  44,8x89,8 A17783","url":"https://plitki-spb.ru/catalog/keramogranit-pamir-svetlo-seryy-45x90","offers":{"@type":"Offer","price":1386,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":4,"item":{"@type":"Product","name":"Глаз. керамогранит Pamir светло-бежевый ректификат 44,8x89,8","url":"https://plitki-spb.ru/catalog/cersanit-pamir-17697","offers":{"@type":"Offer","price":1386,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":5,"item":{"@type":"Product","name":"Глаз. керамогранит Pamir темно-серый рельеф ректификат 44,8x89,8","url":"https://plitki-spb.ru/catalog/cersanit-pamir-17781","offers":{"@type":"Offer","price":1386,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@typ