1f:T8f3,{"@context":"https://schema.org","@type":"ItemList","name":"Коллекция Royal Stone Cersanit","description":"Royal Stone — коллекция, имитирующая благородный натуральный камень с выраженной природной текстурой. Несколько форматов и цветовых решений позволяют создавать гармоничные комбинации стен и пола. Название отражает суть — это «королевский камень» по доступной цене.","url":"https://plitki-spb.ru/collections/royal-stone","numberOfItems":5,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"Мозаика на сетке Cersanit Royal Stone  многоцветный  30x30 RS2L451","url":"https://plitki-spb.ru/catalog/mozaika-royal-stone-mnogotsvetnyy-30x30","offers":{"@type":"Offer","price":1820,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"Керамогранит Cersanit Royal Stone  белый  42x42 RS4R052","url":"https://plitki-spb.ru/catalog/keramogranit-royal-stone-belyy-42x42","offers":{"@type":"Offer","price":1122,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":3,"item":{"@type":"Product","name":"Плитка Cersanit Royal Stone  белый  29,8x59,8 RSL051","url":"https://plitki-spb.ru/catalog/plitka-royal-stone-belyy-30x60","offers":{"@type":"Offer","price":1160,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":4,"item":{"@type":"Product","name":"Плитка Cersanit Royal Stone  черный  29,8x59,8 RSL231","url":"https://plitki-spb.ru/catalog/plitka-royal-stone-chernyy-30x60","offers":{"@type":"Offer","price":1210,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":5,"item":{"@type":"Product","name":"Глаз. керамогранит Royal Stone белый 42x42","url":"https://plitki-spb.ru/catalog/cersanit-royal-stone-17216","offers":{"@type":"Offer","price":1122,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}}]}17:["$","div",nu