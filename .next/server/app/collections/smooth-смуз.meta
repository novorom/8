{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/collections/layout,_N_T_/collections/[collection]/layout,_N_T_/collections/[collection]/page,_N_T_/collections/smooth-%D1%81%D0%BC%D1%83%D0%B7"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/collections/$d$collection/__PAGE__",
    "/collections/$d$collection",
    "/collections",
    "/_index",
    "/_head"
  ]
}