1a:T697,{"@context":"https://schema.org","@type":"ItemList","name":"Коллекция Cambio Cersanit","description":"Cambio — современная серая коллекция в трёх тонах: светло-серый, серый и тёмно-серый. Рельефная матовая поверхность создаёт интересную игру теней. Три тона можно комбинировать между собой для создания многоуровневых интерьеров.","url":"https://plitki-spb.ru/collections/cambio","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"Керамогранит Cersanit Cambio  светло-серый ректификат  рельеф  60x120 A17426","url":"https://plitki-spb.ru/catalog/keramogranit-cambio-svetlo-seryy-60x120","offers":{"@type":"Offer","price":2042,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"Керамогранит Cersanit Cambio  серый ректификат  рельеф  60x120 A17427","url":"https://plitki-spb.ru/catalog/keramogranit-cambio-seryy-60x120","offers":{"@type":"Offer","price":2042,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":3,"item":{"@type":"Product","name":"Керамогранит Cersanit Cambio  темно-серый ректификат  60x120 A17428","url":"https://plitki-spb.ru/catalog/keramogranit-cambio-temno-seryy-60x120","offers":{"@type":"Offer","price":2042,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}}]}12:["$","div",null,{"className":"bg-background min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Коллекции\",\"item\":\"https://plitki-spb.ru/collections\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Cambio\",