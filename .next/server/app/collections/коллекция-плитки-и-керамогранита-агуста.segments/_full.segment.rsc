1c:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Плитка коллекции Коллекция плитки и керамогранита Агуста есть в наличии?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, коллекция Коллекция плитки и керамогранита Агуста от Kerama Marazzi (Керама Марацци) есть в наличии на складе в Янино. Актуальные остатки уточняйте по телефону +7 (905) 205-09-00.\"}},{\"@type\":\"Question\",\"name\":\"Какой формат у плитки Коллекция плитки и керамогранита Агуста?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Уточните форматы коллекции Коллекция плитки и керамогранита Агуста у наших менеджеров по телефону +7 (905) 205-09-00 или в Telegram @flyroman.\"}},{\"@type\":\"Question\",\"name\":\"Есть ли доставка плитки Коллекция плитки и керамогранита Агуста по СПб?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, доставляем коллекцию Коллекция плитки и керамогранита Агуста по Санкт-Петербургу и Ленинградской области от 1 рабочего дня. Самовывоз со склада Янино бесплатный.\"}}]}"}}]
