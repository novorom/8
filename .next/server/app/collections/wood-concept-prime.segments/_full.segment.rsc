1b:T6fa,{"@context":"https://schema.org","@type":"ItemList","name":"Коллекция Wood Concept Prime Cersanit","description":"Wood Concept Prime — вариация серии под дерево в холодных серых тонах. Имитирует состарённую, выбеленную древесину — популярный выбор для скандинавского и лофт-стиля. Тот же длинный формат 21,8×89,8 см и реалистичный рельеф, что и в Natural.","url":"https://plitki-spb.ru/collections/wood-concept-prime","numberOfItems":3,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"Керамогранит Cersanit Wood Concept Prime  серый ректификат  рельеф  21,8x89,8 WP4T093","url":"https://plitki-spb.ru/catalog/keramogranit-wood-concept-prime-seryy-22x90","offers":{"@type":"Offer","price":1610,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"Керамогранит Cersanit Wood Concept Prime  светло-серый ректификат  рельеф  21,8x89,8 WP4T523","url":"https://plitki-spb.ru/catalog/keramogranit-wood-concept-prime-svetlo-seryy-22x90","offers":{"@type":"Offer","price":1610,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":3,"item":{"@type":"Product","name":"Керамогранит Cersanit Wood Concept Prime  белый ректификат  рельеф  21,8x89,8 A15989","url":"https://plitki-spb.ru/catalog/keramogranit-wood-concept-prime-belyy-22x90","offers":{"@type":"Offer","price":1610,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}}]}13:["$","div",null,{"className":"bg-background min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1b"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Колле