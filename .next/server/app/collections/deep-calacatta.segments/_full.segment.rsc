1f:T59b,{"@context":"https://schema.org","@type":"ItemList","name":"Коллекция Deep Calacatta Cersanit","description":"Deep Calacatta — флагманская коллекция Cersanit в крупном формате 60×120 см. Глубокий рисунок белого мрамора с выраженными прожилками выглядит максимально реалистично на большом полотне. Доступна в двух версиях: полированная (High Gloss) для стен и матовая ректификат для пола.","url":"https://plitki-spb.ru/collections/deep-calacatta","numberOfItems":2,"itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Product","name":"Керамогранит Cersanit Deep Calacatta  белый ректификат  60x120 A17126","url":"https://plitki-spb.ru/catalog/keramogranit-deep-calacatta-belyy-60x120","offers":{"@type":"Offer","price":2213,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}},{"@type":"ListItem","position":2,"item":{"@type":"Product","name":"Керамогранит Cersanit Deep Calacatta полированный белый ректификат  60x120 A17127","url":"https://plitki-spb.ru/catalog/keramogranit-deep-calacatta-belyy-60x120-polirovannaya","offers":{"@type":"Offer","price":2213,"priceCurrency":"RUB","availability":"https://schema.org/InStock"}}}]}17:["$","div",null,{"className":"bg-background min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1f"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Коллекции\",\"item\":\"https://plitki-spb.ru/collections\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Deep Calacatta\",\"item\":\"https://plitki-spb.ru/collections/deep-calacatta\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mai