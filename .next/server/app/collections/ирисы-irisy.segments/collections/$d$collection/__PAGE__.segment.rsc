4:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Плитка коллекции Ирисы (Irisy) есть в наличии?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, коллекция Ирисы (Irisy) от ТМ «1721 Ceramique Imperiale» есть в наличии на складе в Янино. Актуальные остатки уточняйте по телефону +7 (905) 205-09-00.\"}},{\"@type\":\"Question\",\"name\":\"Какой формат у плитки Ирисы (Irisy)?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Уточните форматы коллекции Ирисы (Irisy) у наших менеджеров по телефону +7 (905) 205-09-00 или в Telegram @flyroman.\"}},{\"@type\":\"Question\",\"name\":\"Есть ли доставка плитки Ирисы (Irisy) по СПб?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, доставляем коллекцию Ирисы (Irisy) по Санкт-Петербургу и Ленинградской области от 1 рабочего дня. Самовывоз со склада Янино бесплатный.\"}}]}"}}]
