2:T7a5,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как быстро доставляют плитку по Санкт-Петербургу?","acceptedAnswer":{"@type":"Answer","text":"Доставка по СПб и Ленинградской области осуществляется в течение 1-2 рабочих дней с момента оплаты заказа. Самовывоз со склада в Янино возможен в день оплаты в рабочее время (Пн-Пт 10:00-16:45)."}},{"@type":"Question","name":"Можно ли посмотреть плитку перед покупкой?","acceptedAnswer":{"@type":"Answer","text":"Да, вы можете приехать на наш склад в Янино и увидеть все образцы плитки вживую. Наши консультанты помогут подобрать плитку и рассчитать необходимое количество для вашего проекта."}},{"@type":"Question","name":"Какие способы оплаты принимаете?","acceptedAnswer":{"@type":"Answer","text":"Принимаем наличный и безналичный расчёт. Для юридических лиц -- оплата по счёту с НДС. При самовывозе со склада возможна оплата картой."}},{"@type":"Question","name":"Работаете ли вы с юридическими лицами и строительными компаниями?","acceptedAnswer":{"@type":"Answer","text":"Да, мы работаем с юридическими лицами и строительными компаниями. Предоставляем все необходимые документы, включая сертификаты качества, счета-фактуры и товарные накладные."}}]}0:{"buildId":"514f6KYUuMn6svVVLWKbh","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Плитка в СПб\",\"item\":\"https://plitki-spb.ru/spb\"}]}"}}],["$","$L3",null,{"data":{"slug":"spb","title":"Купить плитку в СПб — Kerama Marazzi, Cersanit, Азори. Склад Янино","description":"Магазин плитки в Санкт-Петербурге. Более 750 наименований в наличии на складе в Янино. Доставка по СПб и ЛО от 1 дня. Керамическая плитка, керамогранит, мозаика. Самовывоз бесплатно.","h1":"Плитка в Санкт-Петербурге — более 4000 позиций на складе","breadcrumbLabel":"Плитка в СПб","intro":"Интернет-магазин керамической плитки и керамогранита Cersanit с собственным складом в Янино (Ленинградская область). Мы предлагаем полный ассортимент продукции Cersanit с быстрой доставкой по Санкт-Петербургу и Ленинградской области. Более 750 наименований плитки всегда в наличии -- от классического керамогранита до дизайнерской мозаики.","sections":[{"heading":"Широкий ассортимент плитки Cersanit","content":"В нашем каталоге представлен полный ассортимент керамической продукции: настенная и напольная плитка, керамогранит с имитацией дерева, мрамора и бетона, мозаика на сетке, ступени и плинтуса. Все товары сертифицированы и поставляются напрямую с заводов Cersanit в России. Мы работаем только с оригинальной продукцией -- каждая партия проходит контроль качества на нашем складе в Янино."},{"heading":"Доставка плитки по Санкт-Петербургу и области","content":"Доставляем плитку по всему Санкт-Петербургу и Ленинградской области. Отгрузка со склада в Янино -- в течение 1-2 рабочих дней. Самовывоз бесплатный: мы сами загружаем плитку в ваш транспорт. Доставка до подъезда или с заносом в квартиру -- стоимость рассчитывается индивидуально в зависимости от объёма заказа и адреса. Работаем с частными клиентами и строительными компаниями."},{"heading":"Склад плитки в Янино -- всё в наличии","content":"Наш склад расположен в посёлке Янино-1 Ленинградской области. Здесь хранится весь ассортимент плитки Cersanit: от популярных коллекций Calacatta и Wood Concept до новинок. Наличие на складе обновляется ежедневно, поэтому вы можете быть уверены в актуальности информации. Приезжайте на склад, чтобы увидеть плитку вживую и получить бесплатную консультацию."}],"advantages":[{"title":"Склад в Янино","description":"Более 750 позиций всегда в наличии на собственном складе"},{"title":"Быстрая доставка","description":"Отгрузка от 1 рабочего дня по СПб и Ленинградской области"},{"title":"Официальный дилер","description":"Прямые поставки с заводов Cersanit, гарантия подлинности"},{"title":"Бесплатный самовывоз","description":"Заберите плитку со склада в Янино -- мы загрузим сами"}],"faq":[{"question":"Как быстро доставляют плитку по Санкт-Петербургу?","answer":"Доставка по СПб и Ленинградской области осуществляется в течение 1-2 рабочих дней с момента оплаты заказа. Самовывоз со склада в Янино возможен в день оплаты в рабочее время (Пн-Пт 10:00-16:45)."},{"question":"Можно ли посмотреть плитку перед покупкой?","answer":"Да, вы можете приехать на наш склад в Янино и увидеть все образцы плитки вживую. Наши консультанты помогут подобрать плитку и рассчитать необходимое количество для вашего проекта."},{"question":"Какие способы оплаты принимаете?","answer":"Принимаем наличный и безналичный расчёт. Для юридических лиц -- оплата по счёту с НДС. При самовывозе со склада возможна оплата картой."},{"question":"Работаете ли вы с юридическими лицами и строительными компаниями?","answer":"Да, мы работаем с юридическими лицами и строительными компаниями. Предоставляем все необходимые документы, включая сертификаты качества, счета-фактуры и товарные накладные."}],"catalogLink":"/catalog","catalogLinkLabel":"Перейти в каталог плитки","blogLinks":[{"href":"/blog/kak-vybrat-plitku-dlya-vannoj","title":"Как выбрать плитку для ванной","desc":"Советы по выбору"},{"href":"/blog/trendy-plitki-2025","title":"Тренды плитки 2025","desc":"Актуальные тенденции"},{"href":"/blog/formaty-plitki","title":"Форматы плитки","desc":"Какой формат выбрать"}]}}]],["$L4"],"$L5"]}],"loading":null,"isPartial":false}
