10:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Сколько стоит доставка плитки по Санкт-Петербургу?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Стоимость доставки зависит от объёма зака��а и адреса доставки. Самовывоз со склада в Янино бесплатный. Для расчёта стоимости доставки свяжитесь с нами по телефону +7 (905) 205-09-00 или в Telegram @flyroman.\"}},{\"@type\":\"Question\",\"name\":\"Как работает самовывоз со склада?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Оплатите заказ, приезжайте на склад в Янино-1 в рабочее время (Пн-Пт 10:00-16:45). Наша команда загрузит плитку в ваш транспорт. Вам нужен только подходящий автомобиль -- погрузку мы берём на себя.\"}},{\"@type\":\"Question\",\"name\":\"Можно ли получить плитку в день заказа?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, при самовывозе со склада в Янино. Оплатите заказ до 15:00 и приезжайте на склад в тот же день. При доставке по СПб -- минимальный срок 1 рабочий день.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Доставка плитки в СПб\",\"item\":\"https://plitki-spb.ru/dostavka-plitki-spb\"}]}"}}],["$","$L16",null,{"data":{"slug":"dostavka-plitki-spb","title":"Доставка плитки Cersanit по СПб и ЛО -- от 1 дня со склада Янино","description":"Доставка плитки Cersanit по Санкт-Петербургу и Ленинградской области от 1 рабочего дня. Самовывоз бесплатно со склада в Янино. Доставка до подъезда и с заносом. Работаем с частными клиентами и строительными компаниями.","h1":"Доставка плитки Cersanit по Санкт-Петербургу","breadcrumbLabel":"Доставка плитки в СПб","intro":"Мы обеспечиваем быструю и надёжную доставку керамической плитки и керамогранита Cersanit по всему Санкт-Петербургу и Ленинградской области. Собственный склад в Янино позволяет отгружать заказы в течение 1-2 рабочих дней. Также доступен бесплатный самовывоз -- мы загружаем плитку в ваш транспорт своими силами.","sections":[{"heading":"Самовывоз со склада в Янино","content":"Бесплатный самовывоз со склада в посёлке Янино-1 (Ленинградская область). Режим работы: Пн-Пт с 10:00 до 16:45. Наша команда погрузит плитку в ваш транспорт -- вам не нужно заботиться о погрузке. Чтобы забрать заказ, достаточно оплатить его заранее и приехать на склад в рабочее время."},{"heading":"Доставка по Санкт-Петербургу и ЛО","content":"Доставляем плитку по всему Санкт-Петербургу и Ленинградской области. Варианты: до подъезда вашего дома или с заносом в квартиру/дом. Стоимость рассчитывается индивидуально в зависимости от объёма заказа и адреса доставки. Свяжитесь с нами для расчёта стоимости. Работаем с частными клиентами и строительными организациями."},{"heading":"Доставка по России","content":"Отправляем плитку по всей России транспортными компаниями СДЭК и Деловые линии. Срок доставки -- от 3 до 7 рабочих дней в зависимости от региона. Все товары надёжно упакованы для безопасной транспортировки. Для юридических лиц предоставляем полный комплект документов."}],"advantages":[{"title":"Бесплатный самовывоз","description":"Загружаем плитку в ваш транспорт на складе Янино"},{"title":"Доставка от 1 дня","description":"Быстрая отгрузка по Санкт-Петербургу и ЛО"},{"title":"По всей России","description":"СДЭК, Деловые линии -- от 3 дней"},{"title":"С заносом","description":"Доставка до подъезда или с заносом в квартиру"}],"faq":[{"question":"Сколько стоит доставка плитки по Санкт-Петербургу?","answer":"Стоимость доставки зависит от объёма зака��а и адреса доставки. Самовывоз со склада в Янино бесплатный. Для расчёта стоимости доставки свяжитесь с нами по телефону +7 (905) 205-09-00 или в Telegram @flyroman."},{"question":"Как работает самовывоз со склада?","answer":"Оплатите заказ, приезжайте на склад в Янино-1 в рабочее время (Пн-Пт 10:00-16:45). Наша команда загрузит плитку в ваш транспорт. Вам нужен только подходящий автомобиль -- погрузку мы берём на себя."},{"question":"Можно ли получить плитку в день заказа?","answer":"Да, при самовывозе со склада в Янино. Оплатите заказ до 15:00 и приезжайте на склад в тот же день. При доставке по СПб -- минимальный срок 1 рабочий день."}],"catalogLink":"/delivery","catalogLinkLabel":"Подробнее о доставке","blogLinks":[{"href":"/blog/skolko-plitki-nuzhno-kupit","title":"Сколько плитки нужно купить","desc":"Расчёт количества с запасом."},{"href":"/blog/kak-ukladyvat-plitku","title":"Как укладывать плитку","desc":"Подготовка к укладке после доставки."},{"href":"/blog/sertifikaty-kachestva","title":"Сертификаты качества","desc":"Документы на плитку Cersanit."}]}}]],["$L17","$L18"],"$L19"]}]
