0:{"buildId":"514f6KYUuMn6svVVLWKbh","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"Где находится магазин плитки в СПб?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Наш склад и шоурум расположены в посёлке Янино-1, Ленинградская область (район Всеволожского района). Это в 15-20 минутах от КАД. Режим работы: Пн-Пт 10:00-16:45.\"}},{\"@type\":\"Question\",\"name\":\"Вы официальный дилер Cersanit?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, мы являемся официальным дилером Cersanit в России. Все товары поставляются напрямую с заводов, имеют сертификаты качества и гарантию производителя.\"}},{\"@type\":\"Question\",\"name\":\"Есть ли скидки при большом заказе?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Да, для крупных заказов и строительных компаний предусмотрены специальные условия. Свяжитесь с нами для получения индивидуального предложения по телефону +7 (905) 205-09-00.\"}}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Главная\",\"item\":\"https://plitki-spb.ru\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Магазин плитки в СПб\",\"item\":\"https://plitki-spb.ru/magazin-plitki-spb\"}]}"}}],["$","$L2",null,{"data":{"slug":"magazin-plitki-spb","title":"Магазин плитки в СПб -- склад в Янино, доставка по городу","description":"Магазин керамической плитки и керамогранита Cersanit в Санкт-Петербурге. Склад и шоурум в Янино. Более 750 позиций в наличии. С 2011 года на рынке. Доставка по СПб и ЛО.","h1":"Магазин плитки в Санкт-Петербурге","breadcrumbLabel":"Магазин плитки в СПб","intro":"Дом Плитки -- это специализированный магазин керамической продукции Cersanit в Санкт-Петербурге. С 2011 года мы помогаем тысячам клиентов найти идеальную плитку для их проектов. Собственный склад и шоурум расположены в Янино (Ленинградская область), где вы можете увидеть все образцы вживую и получить профессиональную консультацию.","sections":[{"heading":"Более 13 лет на рынке плитки","content":"Мы работаем с 2011 года и за это время обслужили тысячи клиентов -- от владельцев квартир до крупных строительных компаний. Наш опыт позволяет подобрать оптимальное решение для любого проекта: ремонт ванной комнаты, облицовка кухни, укладка пола в загородном доме. Отзывы о нашей работе можно прочитать на Avito."},{"heading":"Склад и шоурум в Янино","content":"На нашем складе в Янино-1 всегда в наличии более 750 позиций керамической плитки и керамогранита Cersanit. Здесь же расположен шоурум, где вы можете увидеть образцы плитки вживую, оценить цвет и текстуру, получить бесплатную консультацию. Режим работы: Пн-Пт 10:00-16:45."},{"heading":"Наши услуги","content":"Помимо продажи плитки мы оказываем дополнительные услуги: бесплатный расчёт необходимого количества плитки, подбор коллекций по стилю интерьера, доставка по СПб и ЛО, отгрузка по всей России через транспортные компании. Для юридических лиц -- работа по безналичному расчёту с НДС."}],"advantages":[{"title":"С 2011 года","description":"Более 13 лет на рынке керамической плитки в СПб"},{"title":"750+ позиций","description":"Полный ассортимент Cersanit всегда в наличии"},{"title":"Шоурум в Янино","description":"Увидьте плитку вживую перед покупкой"},{"title":"Отзывы на Avito","description":"Реальные отзывы тысяч довольных клиентов"}],"faq":[{"question":"Где находится магазин плитки в СПб?","answer":"Наш склад и шоурум расположены в посёлке Янино-1, Ленинградская область (район Всеволожского района). Это в 15-20 минутах от КАД. Режим работы: Пн-Пт 10:00-16:45."},{"question":"Вы официальный дилер Cersanit?","answer":"Да, мы являемся официальным дилером Cersanit в России. Все товары поставляются напрямую с заводов, имеют сертификаты качества и гарантию производителя."},{"question":"Есть ли скидки при большом заказе?","answer":"Да, для крупных заказов и строительных компаний предусмотрены специальные условия. Свяжитесь с нами для получения индивидуального предложения по телефону +7 (905) 205-09-00."}],"catalogLink":"/catalog","catalogLinkLabel":"Перейти в каталог","blogLinks":[{"href":"/blog/trendy-plitki-2025","title":"Тренды плитки 2025","desc":"Актуальные коллекции в магазине."},{"href":"/blog/formaty-plitki","title":"Форматы плитки","desc":"Какой размер выбрать."},{"href":"/blog/sertifikaty-kachestva","title":"Сертификаты качества","desc":"Официальный дилер Cersanit."}]}}]],["$L3"],"$L4"]}],"loading":null,"isPartial":false}
